{
  "name": "breakout",
  "version": "0.1.0",
  "private": true,
  "description": "Multiplayer Breakout — 1v1 shared-arena versus, server-authoritative",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "dev": "npm-run-all -p dev:server dev:client",
    "build:shared": "npm --workspace shared run build",
    "build:server": "npm --workspace server run build",
    "build:client": "npm --workspace client run build",
    "build": "npm run build:shared && npm-run-all -p build:server build:client"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "~5.7.2"
  }
}
